{
  "name": "ielts-reading-past-papers",
  "version": "2.0.0",
  "license": "GPL-3.0",
  "description": "IELTS Reading Past Papers",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev-manager.mjs up",
    "dev:up": "node scripts/dev-manager.mjs up",
    "dev:down": "node scripts/dev-manager.mjs down",
    "dev:status": "node scripts/dev-manager.mjs status",
    "dev:logs": "node scripts/dev-manager.mjs logs",
    "dev:raw": "concurrently \"npm:dev:web\" \"npm:dev:assistant\"",
    "dev:web": "vite --port 5175 --strictPort",
    "dev:assistant": "npm --prefix server run dev",
    "build": "vite build",
    "preview": "vite preview",
    "generate:index": "node scripts/generate-index.mjs",
    "validate:index": "node scripts/validate-index.mjs",
    "verify:deployment": "node scripts/check-deployment.mjs",
    "audit:question-nav:static": "node scripts/audit-question-nav-static.mjs",
    "audit:question-nav:e2e": "playwright test --config=playwright.config.ts",
    "audit:question-nav": "npm run audit:question-nav:static && npm run audit:question-nav:e2e",
    "test:server": "npm --prefix server run test",
    "eval:rag": "cd evals/ragas && python run_eval.py --all",
    "rag:up": "docker compose -f docker-compose.rag.local.yml up -d",
    "rag:down": "docker compose -f docker-compose.rag.local.yml down",
    "rag:logs": "docker compose -f docker-compose.rag.local.yml logs -f",
    "rag:ps": "docker compose -f docker-compose.rag.local.yml ps"
  },
  "dependencies": {
    "ant-design-vue": "^4.0.0",
    "dompurify": "^3.3.3",
    "marked": "^17.0.6",
    "pinia": "^2.1.0",
    "vue": "^3.4.0",
    "vue-router": "^4.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/dompurify": "^3.0.5",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.6",
    "concurrently": "^9.2.1",
    "happy-dom": "^20.8.3",
    "playwright-core": "^1.59.1",
    "vite": "^5.0.0",
    "vitest": "^4.0.18"
  }
}
