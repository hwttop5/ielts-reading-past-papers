{
  "name": "ielts-reading-past-papers-server",
  "version": "2.0.5",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run -c vitest.config.ts",
    "test:watch": "vitest -c vitest.config.ts",
    "ingest": "tsx src/cli/ingest.ts",
    "check:index": "tsx src/cli/check-index.ts",
    "generate:similar": "tsx src/cli/generateSimilarMap.ts",
    "check:similar": "tsx src/cli/generateSimilarMap.ts --check",
    "eval:rag": "cd ../evals/ragas && python run_eval.py --all",
    "eval:rag:retrieval": "cd ../evals/ragas && python run_eval.py --retrieval",
    "eval:rag:answer": "cd ../evals/ragas && python run_eval.py --answers"
  },
  "dependencies": {
    "@langchain/core": "^0.3.73",
    "@langchain/openai": "^0.6.14",
    "cheerio": "^1.1.2",
    "dotenv": "^16.6.1",
    "fast-glob": "^3.3.3",
    "fastify": "^5.6.1",
    "zod": "^4.1.11",
    "@types/node": "^24.6.2",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "tsx": "^4.20.6",
    "vitest": "^4.0.18"
  }
}
