# Default assistant runtime: OpenRouter free model router
LLM_PROVIDER=openrouter
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_CHAT_MODEL=openrouter/free
LLM_TIMEOUT_MS=35000
LLM_APP_URL=
LLM_APP_NAME=IELTS Reading Past Papers
# Aliyun Coding Plan legacy alternative:
# LLM_PROVIDER=coding-plan
# LLM_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
# LLM_CHAT_MODEL=qwen3.5-plus
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4.1-mini
# --- Embeddings + Qdrant (RAG). Prefer EMBEDDING_* for local TEI; legacy OPENAI_* still supported. ---
EMBEDDING_PROVIDER=openai_compatible
EMBEDDING_BASE_URL=http://127.0.0.1:8080/v1
EMBEDDING_API_KEY=-
EMBEDDING_MODEL=text-embeddings-inference
EMBEDDING_BATCH_SIZE=32
OPENAI_EMBED_MODEL=text-embedding-3-small
# OPENAI_EMBEDDING_BASE_URL=
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_CHUNKS=ielts_question_chunks_v1
QDRANT_COLLECTION_SUMMARIES=ielts_question_summaries_v1
FRONTEND_ORIGIN=http://localhost:5175
# Assistant HTTP API: max POSTs per IP per window (both /api/assistant/query and /query/stream count).
# In NODE_ENV=development, requests from localhost loopback are not counted.
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MINUTES=60
PORT=8787
# Set true to always attach retrievedChunks to assistant JSON (for RAG eval). Otherwise use header X-Assistant-Eval: 1 in development/localhost.
# ASSISTANT_INCLUDE_RETRIEVAL=true
