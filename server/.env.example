# Default assistant runtime: Aliyun Coding Plan
LLM_PROVIDER=coding-plan
LLM_API_KEY=
LLM_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
LLM_CHAT_MODEL=qwen3.5-plus
LLM_TIMEOUT_MS=35000
LLM_APP_URL=
LLM_APP_NAME=IELTS Reading Past Papers
# OpenRouter alternative:
# LLM_PROVIDER=openrouter
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_CHAT_MODEL=stepfun/step-3.5-flash:free
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION_CHUNKS=ielts_question_chunks_v1
QDRANT_COLLECTION_SUMMARIES=ielts_question_summaries_v1
FRONTEND_ORIGIN=http://localhost:5173
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MINUTES=60
PORT=8787
