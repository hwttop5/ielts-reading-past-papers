# Production frontend build: copy to ".env.production" locally (gitignored) or set the same key in
# Vercel → Project → Settings → Environment Variables → Production.
# Required for `npm run build` unless SKIP_ASSISTANT_ENV_CHECK=1 (local test only).
# No trailing slash. Example: https://your-assistant.onrender.com
#
VITE_ASSISTANT_API_BASE_URL=

# Self-hosted Docker + bundled nginx same-origin mode.
# When set to 1, production build allows empty `VITE_ASSISTANT_API_BASE_URL`
# and the frontend uses same-origin `/api`.
# VITE_SELF_HOSTED_SAME_ORIGIN=1

# Optional Baidu Tongji site id. This is baked into the frontend at build time.
# Leave empty to disable Baidu Analytics.
# VITE_BAIDU_TONGJI_ID=
