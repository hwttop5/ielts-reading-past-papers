# Leave unset for local `npm run dev:web`: the app uses same-origin `/api` and Vite proxies to 8787.
# Never set `VITE_ASSISTANT_API_BASE_URL=http://127.0.0.1:8787` (or localhost:8787) for Vite dev — that
# bypasses the proxy and assistant requests can fail (cross-origin / streaming). Use an empty value + proxy.
# Shell/CI can still inject `VITE_ASSISTANT_API_BASE_URL` (e.g. to https://example.com) and override this file — unset it in your environment for local dev.
#
# Production build: see also `.env.production.example` (copy to `.env.production` for local builds).
# REQUIRED for `npm run build` / Vercel Production — vite build fails if unset (unless SKIP_ASSISTANT_ENV_CHECK=1).
# Assistant API root (https://..., no trailing slash). Runtime precedence in the browser:
#   1) VITE_ASSISTANT_API_BASE_URL (baked in at build time)
#   2) public/assistant-api.json → "apiBaseUrl" (runtime; non-empty only; edit + redeploy)
# VITE_ASSISTANT_API_BASE_URL=https://your-assistant.example.com
#
# Local production bundle test only (do not use in CI/Vercel):
# SKIP_ASSISTANT_ENV_CHECK=1
#
# Production deploy: connect this repo on Vercel (branch main) and on Render Web Service (root server/, branch main).
# No GitHub Actions secrets required — see README "部署".

# Copy the variables below into server/.env for local assistant runtime.
LLM_PROVIDER=openrouter
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_CHAT_MODEL=stepfun/step-3.5-flash:free
LLM_TIMEOUT_MS=35000
LLM_APP_URL=http://localhost:5175
LLM_APP_NAME=IELTS Reading Past Papers

# RAG: copy into server/.env — embeddings (EMBEDDING_* preferred) + Qdrant. See README "本地 RAG".
# EMBEDDING_BASE_URL=http://127.0.0.1:8080/v1
# EMBEDDING_API_KEY=-
# EMBEDDING_MODEL=text-embeddings-inference
# QDRANT_URL=http://127.0.0.1:6333
# OPENAI_API_KEY=
# OPENAI_EMBED_MODEL=text-embedding-3-small
# QDRANT_API_KEY=
