                {
                  "type": "element",
                  "tag": "p",
                  "attrs": {},
                  "children": [
                    {
                      "type": "text",
                      "text": "People sometimes say that "
                    },
                    {
                      "type": "element",
                      "tag": "strong",
                      "attrs": {},
                      "children": [
                        {
                          "type": "text",
                          "text": "22"
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "text": " "
