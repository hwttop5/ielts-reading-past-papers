                  "children": [
                    {
                      "type": "text",
                      "text": "\n                    A Bristol University study looked at how insects make decisions when their home has been "
                    },
                    {
                      "type": "element",
                      "tag": "strong",
                      "attrs": {},
                      "children": [
                        {
                          "type": "text",
