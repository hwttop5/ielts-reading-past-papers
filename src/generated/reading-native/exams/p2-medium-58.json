                        "id": "q24_input"
                      }
                    },
                    {
                      "type": "text",
                      "text": ". The ants in the experiment relied on the use of individuals called "
                    },
                    {
                      "type": "element",
                      "tag": "strong",
                      "attrs": {},
                      "children": [
                        {
                          "type": "text",
                          "text": "25"
