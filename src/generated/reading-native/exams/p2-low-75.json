          "tag": "div",
          "attrs": {
            "class": "empty-space"
          },
          "children": []
        },
        {
          "type": "text",
          "text": "\n        "
        },
        {
          "type": "text",
          "text": "\n        \n        "
        },
        {
          "type": "element",
          "tag": "div",
          "attrs": {
            "id": "divider"
          },
          "children": []
