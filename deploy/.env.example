# Copy to `deploy/.env` before `docker compose up -d`.
# This file is for Linux server self-hosting with bundled nginx + same-origin `/api`.

FRONTEND_ORIGIN=https://your-domain.example

LLM_PROVIDER=openrouter
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_CHAT_MODEL=openrouter/free
LLM_TIMEOUT_MS=35000
LLM_APP_URL=https://your-domain.example
LLM_APP_NAME=IELTS Reading Past Papers

ASSISTANT_GENERATION_MODE=llm_preferred
ASSISTANT_ROUTER_ENABLED=true
ASSISTANT_STREAM_ENABLED=true
ASSISTANT_FAST_TIMEOUT_MS=25000
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MINUTES=60

EMBEDDING_PROVIDER=openai_compatible
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BATCH_SIZE=32

OPENAI_API_KEY=
OPENAI_EMBEDDING_BASE_URL=
OPENAI_EMBED_MODEL=text-embedding-3-small

QDRANT_API_KEY=
QDRANT_COLLECTION_CHUNKS=ielts_question_chunks_v1
QDRANT_COLLECTION_SUMMARIES=ielts_question_summaries_v1

TAVILY_API_KEY=
